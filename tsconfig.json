{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "eslint.config.js",
    "ecosystem.config.cjs"
  ],
  "exclude": ["node_modules"]
}
